---
import Layout from "@/layouts/Layout.astro";
import Contacto from "@/components/sections/Contacto.astro";
import ContactForm from "@/components/contact/ContactForm";
import { getI18N } from "@/i18n/i18n";
const t = getI18N({ currentLocale: "es" });
---

<Layout title={`${t.contact.title} | Homii`} description={t.contact.subtitle}>
  <Contacto currentLocale="es" />
  <section class="container-x max-w-6xl">
    <div
      class="rounded-3xl border border-[var(--border)] bg-[var(--bg)] p-6 sm:p-10 shadow-sm relative overflow-hidden"
    >
      <div class="relative z-10">
        <ContactForm client:visible />
      </div>
    </div>
  </section>
</Layout>
