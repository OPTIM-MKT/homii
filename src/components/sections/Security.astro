---
import { getI18N } from "@/i18n/i18n";
import SectionHeader from "@/components/ui/SectionHeader";
import ScrollReveal from "@/components/ui/ScrollRevea";

interface Props {
  currentLocale?: "es" | "en";
}
const { currentLocale = (Astro.currentLocale as "es" | "en") ?? "es" } =
  Astro.props;
const t = getI18N({ currentLocale });
---

<section id="security" class="relative overflow-hidden py-20 md:py-28">
  <div class="container-x">
    <SectionHeader
      client:load
      eyebrow={t.security.eyebrow}
      title={t.security.title}
      subtitle={t.security.subtitle}
    />

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.security.badges.map((badge, i) => (
          <ScrollReveal client:load delay={i * 0.08}>
            <div class="flex h-full items-center gap-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-2)] p-5">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/15 text-primary">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4Z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              </div>
              <p class="text-sm font-medium leading-snug text-[var(--fg)]">
                {badge}
              </p>
            </div>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>
