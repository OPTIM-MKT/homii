---
import { Image } from "astro:assets";
import cel from "@/assets/cel.png";
import { getI18N } from "@/i18n/i18n";
import Button from "@/components/ui/Button";
import StoreButton from "@/components/ui/StoreButton";
import ScrollReveal from "@/components/ui/ScrollRevea";

interface Props {
  currentLocale?: "es" | "en";
}
const { currentLocale = (Astro.currentLocale as "es" | "en") ?? "es" } =
  Astro.props;
const t = getI18N({ currentLocale });
const prefix = currentLocale === "es" ? "" : "/en";

const heroBg =
  "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&q=80&w=2000";

const stats = [
  t.hero.stats.residents,
  t.hero.stats.buildings,
  t.hero.stats.uptime,
];
---

<section
  id="home"
  class="relative isolate overflow-hidden pt-32 pb-20 md:pt-40 md:pb-28"
>
  <div class="absolute inset-0 -z-10">
    <img
      src={heroBg}
      alt=""
      class="h-full w-full object-cover opacity-25 dark:opacity-20"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-[var(--bg)]/40 via-[var(--bg)]/80 to-[var(--bg)]"
    >
    </div>
    <div
      class="pointer-events-none absolute -top-24 left-1/2 h-[420px] w-[720px] -translate-x-1/2 rounded-full bg-primary/20 blur-3xl"
    >
    </div>
  </div>

  <div class="container-x grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
    <ScrollReveal client:load>
      <div class="flex flex-col gap-6">
        <h1 class="heading-xl text-[var(--fg)]">
          {t.hero.title}
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-muted">
          {t.hero.subtitle}
        </p>

        <div class="mt-2 flex flex-wrap items-center gap-3">
          <Button href={`${prefix}/#demo`} size="lg">{t.hero.cta}</Button>
          <Button href={`${prefix}/#features`} size="lg" variant="outline">
            {t.hero.ctaSecondary}
          </Button>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
          <StoreButton
            store="appStore"
            href={t.download.appStore.href}
            caption={t.download.appStore.caption}
            storeName={t.download.appStore.store}
            ariaLabel={t.download.appStore.ariaLabel}
          />
          <StoreButton
            store="playStore"
            href={t.download.playStore.href}
            caption={t.download.playStore.caption}
            storeName={t.download.playStore.store}
            ariaLabel={t.download.playStore.ariaLabel}
          />
        </div>
      </div>
    </ScrollReveal>

    <ScrollReveal client:load direction="left" delay={0.2}>
      <div class="relative mx-auto flex w-full max-w-[280px] items-center justify-center sm:max-w-[320px] lg:max-w-[340px]">
        <div
          class="pointer-events-none absolute inset-0 -z-10 scale-125 rounded-full bg-gradient-to-tr from-primary/30 via-bluePrimary/20 to-transparent blur-3xl"
        >
        </div>
        <Image
          src={cel}
          alt="Homii app preview"
          widths={[280, 340, 473]}
          sizes="(min-width: 1024px) 340px, (min-width: 640px) 320px, 280px"
          class="h-auto w-full object-contain drop-shadow-[0_40px_80px_rgba(0,0,0,0.35)]"
        />
      </div>
    </ScrollReveal>
  </div>

  <div class="container-x mt-16 md:mt-24">
    <ScrollReveal client:load delay={0.3}>
      <div
        class="grid gap-6 rounded-3xl border border-[var(--border)] bg-[var(--bg-2)]/60 p-8 backdrop-blur-sm sm:grid-cols-3"
      >
        {
          stats.map((s) => (
            <div class="text-center">
              <div class="text-3xl font-bold tracking-tight text-[var(--fg)] md:text-4xl">
                {s.value}
              </div>
              <div class="mt-1 text-sm text-muted">{s.label}</div>
            </div>
          ))
        }
      </div>
    </ScrollReveal>
  </div>
</section>
