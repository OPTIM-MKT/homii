---
import { Image } from "astro:assets";
import logo from "@/assets/homii-logo.png";

interface Props {
  href?: string;
  height?: number;
  className?: string;
}

const { href = "/", height = 32, className = "" } = Astro.props;
const aspect = 1500 / 484;
const width = Math.round(height * aspect);
---

<a
  href={href}
  class={`inline-flex items-center ${className}`}
  aria-label="Homii"
>
  <Image
    src={logo}
    alt="Homii"
    width={width}
    height={height}
    class="h-auto w-auto object-contain"
    style={`height:${height}px`}
  />
</a>
