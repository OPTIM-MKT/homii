---
import { Image } from "astro:assets";
import logo from "@/assets/homii-logo.png";

interface Props {
  href?: string;
  height?: number;
  className?: string;
}

const { href = "/", height = 32, className = "" } = Astro.props;
const aspect = 2690 / 1247;
const width = Math.round(height * aspect);
---

<a
  href={href}
  class={`inline-flex items-center  ${className}`}
  aria-label="Homii"
>
  <Image
    src={logo}
    alt="Homii"
    width={width}
    height={height}
    style={`height: ${height}px; width: auto;`}
    class="object-contain"
  />
</a>
