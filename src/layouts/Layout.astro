---
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import "@/styles/global.css";
import { getI18N } from "@/i18n/i18n";
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import SmoothScroll from "@/components/ui/SmoothScroll";
import ScrollTop from "@/components/ui/ScrollTop.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
}

const currentLocale = (Astro.currentLocale as "es" | "en") ?? "es";
const t = getI18N({ currentLocale });

const {
  title = t.seo.title,
  description = t.seo.description,
  keywords = t.seo.keywords,
  image = t.seo.ogImage,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url,
).toString();
const ogImage = new URL(image, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#09AD05" />
    <link rel="icon" href="/homii.ico" />
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title,
          type: "website",
          image: ogImage,
          url: canonicalURL,
        },
        optional: {
          description,
          siteName: t.seo.siteName,
          locale: currentLocale,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        description,
        image: ogImage,
      }}
      extend={{
        meta: [
          { name: "keywords", content: keywords },
          { name: "author", content: "Homii" },
          { name: "robots", content: "index, follow" },
        ],
      }}
    />
    <ClientRouter />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          var theme = stored || (prefersDark ? "dark" : "light");
          if (theme === "dark") document.documentElement.classList.add("dark");
          else document.documentElement.classList.remove("dark");
        } catch (_) {}
      })();

      document.addEventListener("astro:after-swap", function () {
        try {
          var theme = localStorage.getItem("theme") || "light";
          if (theme === "dark") document.documentElement.classList.add("dark");
          else document.documentElement.classList.remove("dark");
        } catch (_) {}
      });
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <SmoothScroll client:load />
    <Navbar currentLocale={currentLocale} />
    <main>
      <slot />
    </main>
    <Footer currentLocale={currentLocale} />
    <ScrollTop />
  </body>
</html>
